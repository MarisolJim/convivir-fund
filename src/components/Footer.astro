---
const year = new Date().getFullYear();
---

<footer class="bg-blue border-t border-white/10 mt-auto">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div>
        <img src="/images/CONVIVIR-logo-white-web.png" alt="Convivir Fund" class="h-8 w-auto" />
        <p class="text-sm text-white/60 mt-2">Living and growing together.</p>
      </div>

      <nav class="flex flex-col sm:flex-row gap-4 sm:gap-6" aria-label="Footer navigation">
        <a href="/" class="text-sm text-white/70 hover:text-orange transition-colors">Home</a>
        <a href="/about" class="text-sm text-white/70 hover:text-orange transition-colors">About</a>
        <a href="/contact" class="text-sm text-white/70 hover:text-orange transition-colors">Contact</a>
      </nav>
    </div>

    <div class="border-t border-white/10 mt-8 pt-6 text-center">
      <p class="text-sm text-white/50">© {year} Convivir Fund. All rights reserved.</p>
    </div>
  </div>
</footer>
