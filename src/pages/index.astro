---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="py-20 md:py-28 relative overflow-hidden">
    <!-- warm radial glow -->
    <div class="absolute -top-20 -left-20 w-96 h-96 bg-forest-100 rounded-full opacity-40 blur-3xl pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-6 relative">
      <div class="max-w-2xl">
        <span style="font-family: var(--font-script);" class="text-3xl text-forest-600">
          A mini-grant fund
        </span>
        <h1 class="font-serif text-4xl md:text-5xl text-charcoal mt-2 mb-5 leading-tight">
          Investing in People,<br />Rooted in Community
        </h1>
        <p class="text-lg text-stone-600 leading-relaxed mb-8">
          The Convivir Fund provides direct financial support to students who are
          traditionally underserved by existing aid programs. Our grants are not
          scholarships — they are emergency and hardship funds designed to remove
          financial barriers so students can remain focused on their education and
          academic success.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/about"
            class="bg-forest-600 hover:bg-forest-700 text-white font-medium px-7 py-3 rounded-full transition-colors"
          >
            About the Fund
          </a>
          <a
            href="/contact"
            class="border-2 border-forest-600 text-forest-600 hover:bg-forest-50 font-medium px-7 py-3 rounded-full transition-colors"
          >
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Accent line ───────────────────────────────────────────── -->
  <div class="max-w-4xl mx-auto px-6">
    <div class="h-px bg-stone-200"></div>
  </div>

  <!-- ── Who We Support ──────────────────────────────────────── -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="mb-10">
        <h2 class="font-serif text-3xl text-charcoal mb-3">Who We Support</h2>
        <p class="text-stone-600 max-w-xl">
          We fund individual students where a little support goes a long way.
          Each grant is $500.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="bg-forest-50 rounded-2xl p-6 border border-forest-100">
          <div class="w-10 h-10 bg-forest-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-charcoal mb-2">Basic Needs</h3>
          <p class="text-sm text-stone-600 leading-relaxed">
            Supporting food-insecure students and those facing housing or financial
            instability that makes it hard to show up and stay in school.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="bg-forest-50 rounded-2xl p-6 border border-forest-100">
          <div class="w-10 h-10 bg-forest-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
            </svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-charcoal mb-2">Participation Costs</h3>
          <p class="text-sm text-stone-600 leading-relaxed">
            Helping students cover the fees, uniforms, and equipment costs that stand
            between them and full participation in sports, clubs, and activities.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="bg-forest-50 rounded-2xl p-6 border border-forest-100">
          <div class="w-10 h-10 bg-forest-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-charcoal mb-2">Relief for Student Workers</h3>
          <p class="text-sm text-stone-600 leading-relaxed">
            Giving working students a moment of relief — so they can reduce hours,
            ease the pressure, and focus on being a student.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA Banner ────────────────────────────────────────────── -->
  <section class="bg-forest-50 border-y border-forest-100 py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-serif text-3xl text-charcoal mb-4">Currently in Pilot</h2>
      <p class="text-stone-600 mb-7 max-w-lg mx-auto">
        The Convivir Fund is currently being piloted in partnership with
        <a href="https://www.diygirls.org" target="_blank" rel="noopener noreferrer" class="text-forest-600 hover:text-forest-700 underline underline-offset-2 transition-colors">DIY Girls</a>.
        We are not accepting open applications at this time. Follow along as the fund grows.
      </p>
      <a
        href="/contact"
        class="bg-forest-600 hover:bg-forest-700 text-white font-medium px-8 py-3 rounded-full transition-colors inline-block"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
